# ============================================================
# SupportFlow AI — example environment configuration
# Copy to `.env` and adjust. NEVER commit a real `.env`.
# ============================================================

# ---- App ----
APP_ENV=development
LOG_LEVEL=info

# ---- Backend (FastAPI) ----
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
# Comma-separated origins allowed by CORS (frontend dev server)
CORS_ORIGINS=http://localhost:3000

# ---- PostgreSQL (introduced in Phase 2) ----
POSTGRES_USER=supportflow
POSTGRES_PASSWORD=supportflow
POSTGRES_DB=supportflow
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
# Full SQLAlchemy URL (override if you prefer a single var)
DATABASE_URL=postgresql+psycopg://supportflow:supportflow@localhost:5432/supportflow

# ---- Ollama (introduced in Phase 4/5) ----
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=mistral:7b
OLLAMA_EMBED_MODEL=nomic-embed-text
# Fallback embeddings if Ollama embeddings misbehave (Phase 4)
EMBED_FALLBACK_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ---- ChromaDB (introduced in Phase 4) ----
CHROMA_PERSIST_DIR=./data/chroma
CHROMA_COLLECTION=supportflow_kb

# ---- Knowledge base ----
KNOWLEDGE_BASE_DIR=./data/knowledge_base

# ---- MLflow (introduced in Phase 11) ----
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT=supportflow

# ---- Monitoring (introduced in Phase 13) ----
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001

# ---- Frontend (introduced in Phase 5.5) ----
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
